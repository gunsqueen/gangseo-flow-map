{
  "name": "gangseo-transit-pipeline",
  "version": "1.0.0",
  "private": true,
  "description": "서울시 강서구 버스정류장/지하철역 승하차 데이터 수집 및 전처리 파이프라인",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "fetch:bus:stops": "node scripts/fetchBusStops.js",
    "fetch:bus:hourly": "node scripts/fetchBusHourly.js",
    "fetch:subway:stations": "node scripts/fetchSubwayStations.js",
    "fetch:subway:hourly": "node scripts/fetchSubwayHourly.js",
    "fetch:all": "node scripts/fetchAll.js",
    "process:gangseo": "node scripts/processGangseoData.js",
    "build:data": "node scripts/fetchAll.js && node scripts/processGangseoData.js"
